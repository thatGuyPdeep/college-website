{
  "name": "college-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "a11y": "node scripts/a11y-check.mjs",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run build && npm run test:e2e",
    "lighthouse": "node scripts/lighthouse-check.mjs",
    "check:env": "node scripts/check-env.mjs",
    "netlify:env": "node scripts/push-netlify-env.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,css}\" --ignore-path .gitignore",
    "db:migrate": "node scripts/migrate.mjs",
    "rag:ingest": "node scripts/ingest-knowledge-base.mjs",
    "prepare": "node -e \"if (process.env.HUSKY !== '0' && process.env.CI !== 'true') { require('child_process').execSync('husky', { stdio: 'inherit' }) }\""
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.59.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.79.0",
    "resend": "^6.14.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@netlify/plugin-nextjs": "^5.15.12",
    "@playwright/test": "^1.61.0",
    "@types/node": "^20.19.43",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "pg": "^8.21.0",
    "prettier": "^3.8.4",
    "typescript": "^5",
    "vitest": "^3.2.6",
    "wait-on": "^9.0.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,json,css,md}": [
      "prettier --write"
    ]
  }
}
