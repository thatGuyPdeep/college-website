-hidden border border-blue-100 shrink-0\"><img alt=\"ITI &amp; Vocational Training\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"192px\" srcSet=\"/_next/image?url=%2Fimages%2Fact-iti.jpg&amp;w=32&amp;q=75 32w, /_next/image?url=%2Fimages%2Fact-iti.jpg&amp;w=48&amp;q=75 48w, /_next/image?url=%2Fimages%2Fact-iti.jpg&amp;w=64&amp;q=75 64w, /_next/image?url=%2Fimages%2Fact-iti.jpg&amp;w=96&amp;q=75 96w, /_next/image?url=%2Fimages%2Fact-iti.jpg&amp;w=128&amp;q=75 128w, /_next/image?url=%2Fimages%2Fact-iti.jpg&amp;w=256&amp;q=75 256w, /_next/image?url=%2Fimages%2Fact-iti.jpg&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fimages%2Fact-iti.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2Fact-iti.jpg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2Fact-iti.jpg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2Fact-iti.jpg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2Fact-iti.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2Fact-iti.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2Fact-iti.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2Fact-iti.jpg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2Fact-iti.jpg&amp;w=3840&amp;q=75\"/></div><div class=\"flex-1 min-w-0\"><h2 class=\"text-2xl font-bold text-[#0D2660] mb-3\">ITI &amp; Vocational Training</h2><p class=\"text-gray-600 leading-relaxed mb-5\">NCVT-affiliated industrial training for tribal youth — see the dedicated ITI page.</p><ul class=\"space-y-2\"><li class=\"flex gap-2 text-sm text-gray-700 leading-relaxed\"><span class=\"text-[#C8201A] font-bold shrink-0\" aria-hidden=\"true\">•</span>Ramakrishna Mission ITI Narayanpur — Electrician, Fitter, Turner, Wireman, COPA, and more</li><li class=\"flex gap-2 text-sm text-gray-700 leading-relaxed\"><span class=\"text-[#C8201A] font-bold shrink-0\" aria-hidden=\"true\">•</span>Admission priority for Abujhmarh tribal youth</li><li class=\"flex gap-2 text-sm text-gray-700 leading-relaxed\"><span class=\"text-[#C8201A] font-bold shrink-0\" aria-hidden=\"true\">•</span>Details at /academics/iti and rkmitinpr.org</li></ul><a class=\"inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-lg text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover:bg-primary/90 h-9 px-4 py-2 mt-5 bg-[#0D2660] text-white\" href=\"/academics/iti\">View ITI Programmes <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right ml-2 h-4 w-4\" aria-hidden=\"true\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a></div></div></article><article id=\"coaching\" class=\"scroll-mt-24\"><div class=\"flex flex-col sm:flex-row gap-6 items-start\"><div class=\"relative w-full sm:w-48 h-32 sm:h-36 rounded-xl overflow-hidden border border-blue-100 shrink-0\"><img alt=\"Free Coaching Center\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"192px\" srcSet=\"/_next/image?url=%2Fimages%2Fact-coaching.jpg&amp;w=32&amp;q=75 32w, /_next/image?url=%2Fimages%2Fact-coaching.jpg&amp;w=48&amp;q=75 48w, /_next/image?url=%2Fimages%2Fact-coaching.jpg&amp;w=64&amp;q=75 64w, /_next/image?url=%2Fimages%2Fact-coaching.jpg&amp;w=96&amp;q=75 96w, /_next/image?url=%2Fimages%2Fact-coaching.jpg&amp;w=128&amp;q=75 128w, /_next/image?url=%2Fimages%2Fact-coaching.jpg&amp;w=256&amp;q=75 256w, /_next/image?url=%2Fimages%2Fact-coaching.jpg&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fimages%2Fact-coaching.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2Fact-coaching.jpg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2Fact-coaching.jpg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2Fact-coaching.jpg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2Fact-coaching.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2Fact-coaching.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2Fact-coaching.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2Fact-coaching.jpg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2Fact-coaching.jpg&amp;w=3840&amp;q=75\"/></div><div class=\"flex-1 min-w-0\"><h2 class=\"text-2xl font-bold text-[#0D2660] mb-3\">Free Coaching Center</h2><p class=\"text-gray-600 leading-relaxed mb-5\">Supplementary coaching for tribal students preparing for board exams and competitive entrance tests.</p><ul class=\"space-y-2\"><li class=\"flex gap-2 text-sm text-gray-700 leading-relaxed\"><span class=\"text-[#C8201A] font-bold shrink-0\" aria-hidden=\"true\">•</span>Free coaching aligned with the Mission&#x27;s ideal that education must reach those who cannot come to it</li><li class=\"flex gap-2 text-sm text-gray-700 leading-relaxed\"><span class=\"text-[#C8201A] font-bold shrink-0\" aria-hidden=\"true\">•</span>Supports students from interior Abujhmarh villages and Vivekananda Vidyapeeth</li></ul></div></div></article><article id=\"ancillary\" class=\"scroll-mt-24\"><div class=\"flex flex-col sm:flex-row gap-6 items-start\"><div class=\"relative w-full sm:w-48 h-32 sm:h-36 rounded-xl overflow-hidden border border-blue-100 shrink-0\"><img alt=\"Ancillary Units\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"192px\" srcSet=\"/_next/image?url=%2Fimages%2Fact-ancillary.jpg&amp;w=32&amp;q=75 32w, /_next/image?url=%2Fimages%2Fact-ancillary.j